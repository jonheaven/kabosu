# Copy to .env and fill in your values
# .env is gitignored — never commit real secrets

DOGE_RPC_USERNAME=doge
DOGE_RPC_PASSWORD=your-strong-rpc-password

POSTGRES_PASSWORD=your-strong-db-password

# Optional: HMAC secret for webhook request signing (X-Kabosu-Signature header)
WEBHOOK_HMAC_SECRET=change-this-to-a-random-string

